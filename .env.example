# SentinelFraud Environment Configuration
# Stage 9: Production hardening
# Copy this to .env and fill in real values

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
ENVIRONMENT=development          # development | staging | production
DEBUG=false
LOG_LEVEL=INFO

# CRITICAL: Change in production - minimum 32 characters
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_use_32+_chars_here
JWT_SECRET_KEY=JWT_SECRET_CHANGE_ME_IN_PROD_32chars_min

# ---------------------------------------------------------------------------
# PostgreSQL 15
# ---------------------------------------------------------------------------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinel_fraud
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40

# ---------------------------------------------------------------------------
# Redis 7
# ---------------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=set_if_needed

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------------------------------------------------------------------------
# ML Configuration
# ---------------------------------------------------------------------------
ML_MODEL_PATH=/app/ml_models
ML_MODEL_THRESHOLD=0.5

# Risk score thresholds
RISK_SCORE_FRAUD_THRESHOLD=70
RISK_SCORE_REVIEW_THRESHOLD=40

# ---------------------------------------------------------------------------
# Fraud Rules Configuration
# ---------------------------------------------------------------------------
CARD_VELOCITY_LIMIT=5
USER_VELOCITY_LIMIT=10
DEVICE_VELOCITY_LIMIT=20
HIGH_AMOUNT_THRESHOLD=10000.0
VERY_HIGH_AMOUNT_THRESHOLD=50000.0
AMOUNT_SPIKE_MULTIPLIER=10.0

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]
ALLOWED_HOSTS=["*"]

# JWT settings
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000
WORKERS=4
